{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchManagers": ["pub"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "labels": ["dependencies", "minor-update"]
    },
    {
      "matchManagers": ["pub"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"],
      "reviewers": [""]
    }
  ],
  "schedule": ["every weekend"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2
}